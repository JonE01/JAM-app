# ================================================================
#  JAM App — environment variables
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to git.
# ================================================================

# ----------------------------------------------------------------
# Firebase
# Get these from: Firebase Console → Project Settings → Your apps
# ----------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----------------------------------------------------------------
# Google Calendar
# OAuth client: https://console.cloud.google.com → APIs & Services → Credentials
# API key:      same page → "Create credentials" → "API key"
# Calendar ID:  Google Calendar → Settings → "Calendar ID" (ends in @group.calendar.google.com)
# ----------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_CALENDAR_ID=your-shared-calendar-id@group.calendar.google.com

# ----------------------------------------------------------------
# iCloud Shared Album
# 1. Open the shared album on iOS → "Share Album" → enable "Public Website"
# 2. The URL will look like: https://www.icloud.com/photos/#AbCdEfGhIjKl
# 3. Paste only the token (the part after #)
# ----------------------------------------------------------------
VITE_ICLOUD_ALBUM_TOKEN=AbCdEfGhIjKl

# ----------------------------------------------------------------
# Anthropic (Claude AI) — used server-side only in api/generate-event.js
# Get from: https://console.anthropic.com
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------
# Map center (set to your city)
# Find coordinates: right-click on Google Maps → "What's here?"
# ----------------------------------------------------------------
VITE_MAP_LAT=40.7128
VITE_MAP_LNG=-74.0060
VITE_MAP_ZOOM=13
